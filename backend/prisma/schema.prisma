generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ExamScore {
  id          BigInt   @id @default(autoincrement())
  sbd         String   @unique @db.VarChar(8)
  toan        Decimal? @db.Decimal(4, 2)
  nguVan      Decimal? @map("ngu_van") @db.Decimal(4, 2)
  ngoaiNgu    Decimal? @map("ngoai_ngu") @db.Decimal(4, 2)
  vatLi       Decimal? @map("vat_li") @db.Decimal(4, 2)
  hoaHoc      Decimal? @map("hoa_hoc") @db.Decimal(4, 2)
  sinhHoc     Decimal? @map("sinh_hoc") @db.Decimal(4, 2)
  lichSu      Decimal? @map("lich_su") @db.Decimal(4, 2)
  diaLi       Decimal? @map("dia_li") @db.Decimal(4, 2)
  gdcd        Decimal? @db.Decimal(4, 2)
  maNgoaiNgu  String?  @map("ma_ngoai_ngu") @db.VarChar(8)
  groupATotal Decimal? @map("group_a_total") @db.Decimal(5, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([groupATotal(sort: Desc)], map: "idx_exam_scores_group_a_total")
  @@map("exam_scores")
}
